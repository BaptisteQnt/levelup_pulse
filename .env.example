##################################
# APPLICATION
##################################

APP_NAME="Level'UP Pulse"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

APP_TIMEZONE=Europe/Paris

##################################
# LOGS
##################################

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

##################################
# DATABASE
##################################

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

##################################
# SESSION / CACHE / QUEUE
##################################

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

CACHE_STORE=redis
QUEUE_CONNECTION=redis

SANCTUM_STATEFUL_DOMAINS=localhost

##################################
# REDIS
##################################

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

##################################
# FILESYSTEM
##################################

FILESYSTEM_DISK=local

##################################
# BROADCAST
##################################

BROADCAST_CONNECTION=log

##################################
# MAIL
##################################

MAIL_MAILER=log
MAIL_SCHEME=
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ENCRYPTION=tls

##################################
# AWS / S3
##################################

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=
AWS_ENDPOINT=

##################################
# DISCORD (Socialite)
##################################

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
DISCORD_BOT_TOKEN=

##################################
# STRIPE / CASHIER
##################################

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

CASHIER_CURRENCY=eur
CASHIER_CURRENCY_LOCALE=fr_FR

##################################
# TELESCOPE
##################################

TELESCOPE_ENABLED=true
TELESCOPE_RECORD_ALL=false
TELESCOPE_PATH=telescope

##################################
# OPENAI
##################################

OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=

OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
OPENAI_MAX_OUTPUT_TOKENS=2000
OPENAI_TIMEOUT_SECONDS=90

##################################
# IA - ARTICLES
##################################

ARTICLE_AI_MODEL=gpt-5.6-terra
ARTICLE_AI_REASONING_EFFORT=low
ARTICLE_AI_TRENDS_MAX_OUTPUT_TOKENS=1800
ARTICLE_AI_CORRECTION_MAX_OUTPUT_TOKENS=12000
ARTICLE_AI_TIMEOUT_SECONDS=90

##################################
# DEEPL
##################################

DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com/v2/translate

##################################
# IGDB / TWITCH
##################################

IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
IGDB_TOKEN_URL=https://id.twitch.tv/oauth2/token
IGDB_GAMES_URL=https://api.igdb.com/v4/games

##################################
# COMPATIBILITY SCAN
##################################

COMPATIBILITY_SCAN_UPLOAD_TTL_MINUTES=15
COMPATIBILITY_SCAN_RETENTION_HOURS=24
COMPATIBILITY_SCAN_MAX_PAYLOAD_BYTES=65536

##################################
# MEMCACHED
##################################

MEMCACHED_HOST=127.0.0.1

##################################
# VITE
##################################

VITE_APP_NAME="${APP_NAME}"

##################################
# STRIPE CLI (Développement)
##################################

# STRIPE_APP_URL=http://127.0.0.1:8000
# STRIPE_FORWARD_URL=http://127.0.0.1:8000/stripe/webhook
# STRIPE_AUTO_LISTEN=false

##################################
# MONITORING
##################################

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0

##################################
# SECURITY
##################################

FORCE_HTTPS=true

##################################
# DEPLOY
##################################

APP_RELEASE=
