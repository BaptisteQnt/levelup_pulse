APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

TELESCOPE_ENABLED=true
TELESCOPE_RECORD_ALL=false
TELESCOPE_PATH=telescope

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SANCTUM_STATEFUL_DOMAINS=localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Analyse de compatibilite PC (deux requetes Responses API par test)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
OPENAI_MAX_OUTPUT_TOKENS=2000
OPENAI_TIMEOUT_SECONDS=90
ARTICLE_AI_MODEL=gpt-5.6-terra
ARTICLE_AI_REASONING_EFFORT=low
ARTICLE_AI_TRENDS_MAX_OUTPUT_TOKENS=1800
ARTICLE_AI_CORRECTION_MAX_OUTPUT_TOKENS=12000
ARTICLE_AI_TIMEOUT_SECONDS=90
COMPATIBILITY_SCAN_UPLOAD_TTL_MINUTES=15
COMPATIBILITY_SCAN_RETENTION_HOURS=24
COMPATIBILITY_SCAN_MAX_PAYLOAD_BYTES=65536

# Active automatiquement `stripe listen` lorsque vous utilisez `composer dev`.
# Décommentez et ajustez les variables ci-dessous pour personnaliser l'URL ou désactiver l'écoute.
# STRIPE_APP_URL=http://127.0.0.1:8000
# STRIPE_FORWARD_URL=http://127.0.0.1:8000/stripe/webhook
# STRIPE_AUTO_LISTEN=false
